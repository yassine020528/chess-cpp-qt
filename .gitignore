# Project architecture:
# - Keep source and project files in Game/Chess/
# - Keep solution files in Game/
# - Keep SVG assets in assets/
# - Ignore Visual Studio, Qt, and compiled build artifacts

# Visual Studio workspace state
.vs/
*.suo
*.user
*.VC.db
*.VC.opendb
*.db-shm
*.db-wal
ipch/

# Build outputs produced by this repo's layout
**/[Dd]ebug/
**/[Rr]elease/
**/x64/
**/x86/

# MSVC / linker outputs
*.obj
*.idb
*.ilk
*.pdb
*.exe
*.dll
*.lib
*.exp
*.recipe
*.tlog
*.lastbuildstate

# Visual Studio generated logs and file lists
*.log
*.FileListAbsolute.txt
*.Build.CppClean.log

# Qt generated files
**/moc/
**/uic/
**/rcc/
**/qmake/
**/qt/
ui_*.h
moc_*.cpp
qrc_*.cpp
qtvars*.props
qtvars*.pro
qtvars*.xml
qt_work.log
import.qml
.qmake.stash
moc_predefs.h*

# Keep real project sources and assets tracked
!Game/
!Game/Chess.sln
!Game/Chess/
!Game/Chess/*.vcxproj
!Game/Chess/*.vcxproj.filters
!Game/Chess/*.cpp
!Game/Chess/*.h
!Game/Chess/*.ui
!Game/Chess/*.qrc
!Game/Chess/cpp.hint
!Game/assets/
!Game/assets/*.svg
!assets/
!assets/*.svg
